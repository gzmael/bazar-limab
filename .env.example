# PostgreSQL (Payload)
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/bazar_lima

PAYLOAD_SECRET=YOUR_SECRET_HERE
RESEND_API_KEY=re_example_api_key

# Public site URL (metadata, canonical, Open Graph, next/image remote patterns)
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Vercel Blob — required for uploads on Vercel (read-only filesystem). Usually auto-set when Blob is enabled on the project.
# Optional locally: omit to use the default ./media folder.
# BLOB_READ_WRITE_TOKEN=
